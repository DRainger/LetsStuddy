<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_nav_graph"
    app:startDestination="@id/roomListFragment">

    <fragment
        android:id="@+id/roomListFragment"
        android:name="com.leststuddy.Roons.ui.RoomListFragment"
        android:label="Study Rooms"
        tools:layout="@layout/fragment_room_list">
        <action
            android:id="@+id/action_roomListFragment_to_profileFragment"
            app:destination="@id/profileFragment" />
        <action
            android:id="@+id/action_roomListFragment_to_roomDetailsFragment"
            app:destination="@id/roomDetailsFragment" />
        <action
            android:id="@+id/action_roomListFragment_to_reservationListFragment"
            app:destination="@id/reservationListFragment" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.leststuddy.Roons.ui.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile" />

    <fragment
        android:id="@+id/roomDetailsFragment"
        android:name="com.leststuddy.Roons.ui.RoomDetailsFragment"
        android:label="Room Details"
        tools:layout="@layout/fragment_room_details">
        <argument
            android:name="roomId"
            app:argType="integer" />
        <action
            android:id="@+id/action_roomDetailsFragment_to_reservationFormFragment"
            app:destination="@id/reservationFormFragment" />
    </fragment>

    <fragment
        android:id="@+id/reservationFormFragment"
        android:name="com.leststuddy.Roons.ui.ReservationFormFragment"
        android:label="Reservation Form"
        tools:layout="@layout/fragment_reservation_form">
        <argument
            android:name="roomId"
            android:defaultValue="-1"
            app:argType="integer" />
        <argument
            android:name="reservationId"
            android:defaultValue="-1"
            app:argType="integer" />
        <action
            android:id="@+id/action_reservationFormFragment_to_reservationListFragment"
            app:destination="@id/reservationListFragment"
            app:popUpTo="@id/roomListFragment" />
    </fragment>

    <fragment
        android:id="@+id/reservationListFragment"
        android:name="com.leststuddy.Roons.ui.ReservationListFragment"
        android:label="My Reservations"
        tools:layout="@layout/fragment_reservation_list">
        <action
            android:id="@+id/action_reservationListFragment_to_reservationFormFragment"
            app:destination="@id/reservationFormFragment" />
    </fragment>
</navigation>
